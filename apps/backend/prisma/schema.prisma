generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

// using a local generator because the published one eithet out of support or doesn't fully supprt ESM
generator zod {
  provider = "prisma-generator-zod-local"
  output   = "../../packages/schemas/src/generated"
}

model Receipt {
  id        String   @id @default(uuid())
  title     String
  amount    Float
  currency  String
  vendor    String?
  createdAt DateTime @default(now())
  projectId String?
  Project   Project? @relation(fields: [projectId], references: [id])
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  projects     Project[]
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  Receipts    Receipt[]
  users       User[]
}
