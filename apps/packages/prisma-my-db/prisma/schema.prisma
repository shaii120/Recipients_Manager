generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// using a local generator because the published one eithet out of support or doesn't fully supprt ESM
generator zod {
  provider = "prisma-generator-zod-local"
  output   = "../../schemas/src/generated"
}

model Receipt {
  id        String   @id @default(uuid())
  title     String
  amount    Float
  currency  String
  vendor    String?
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String

  projects UserProject[]
}

model Project {
  id          String  @id @default(uuid())
  name        String
  description String?

  receipts Receipt[]
  users    UserProject[]
}

model UserProject {
  userId    String
  projectId String

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@id([userId, projectId]) // composite primary key
}
